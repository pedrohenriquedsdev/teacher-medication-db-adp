@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusao de Paciente";
}

@model ExcluirPacienteViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir este paciente?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8 text-break">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Nome</dt>
        <dd class="col-sm-8">@Model.Nome</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Telefone</dt>
        <dd class="col-sm-8">@Model.Telefone</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">CPF</dt>
        <dd class="col-sm-8">@Model.Cpf</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Cartao SUS</dt>
        <dd class="col-sm-8">@Model.CartaoSus</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
