@{
    Layout = "_Layout";
    ViewBag.Titulo = "Historico de Estoque";
}

@model HistoricoEstoqueViewModel;

<section class="mb-4">
    <div class="card border-primary-subtle shadow-sm">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between gap-3">
                <div>
                    <h5 class="card-title mb-1">@Model.MedicamentoNome</h5>
                    <p class="text-secondary mb-1">@Model.MedicamentoDescricao</p>
                    <span class="small text-secondary">Fornecedor: @Model.FornecedorNome</span>
                </div>

                <div class="text-end">
                    <span class="text-secondary small d-block">Estoque atual</span>
                    <span class="fs-4 fw-semibold">@Model.QuantidadeEmEstoque</span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4 justify-content-end">
                <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Medicamento" asp-action="Listar">Voltar</a>
                <a class="btn btn-outline-primary rounded-pill px-4" asp-action="RegistrarEntrada" asp-route-medicamentoId="@Model.MedicamentoId">Entrada</a>
                <a class="btn btn-outline-primary rounded-pill px-4" asp-action="RegistrarSaida" asp-route-medicamentoId="@Model.MedicamentoId">Saida</a>
            </div>
        </div>
    </div>
</section>

<div class="row g-3">
    <section class="col-12 col-lg-6">
        <h5 class="mb-3">Entradas</h5>

        @if (Model.Entradas.Count == 0)
        {
            <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
                Nenhuma entrada registrada.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (ListarRequisicoesEntradaViewModel entrada in Model.Entradas)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between gap-3">
                            <span class="fw-semibold">@entrada.FuncionarioNome</span>
                            <span class="badge text-bg-primary rounded-pill">@entrada.Quantidade</span>
                        </div>
                        <span class="small text-secondary">@entrada.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                }
            </div>
        }
    </section>

    <section class="col-12 col-lg-6">
        <h5 class="mb-3">Saidas</h5>

        @if (Model.Saidas.Count == 0)
        {
            <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
                Nenhuma saida registrada.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (ListarRequisicoesSaidaViewModel saida in Model.Saidas)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between gap-3">
                            <span class="fw-semibold">@saida.PacienteNome</span>
                            <span class="badge text-bg-primary rounded-pill">@saida.Quantidade</span>
                        </div>
                        <span class="small text-secondary">@saida.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                }
            </div>
        }
    </section>
</div>
