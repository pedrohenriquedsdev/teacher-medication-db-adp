@{
    Layout = "_Layout";
    ViewBag.Titulo = "Requisicao de Saida";
}

@model RegistrarSaidaViewModel;

@if (Model.Pacientes.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 720px;" role="alert">
        Cadastre um paciente antes de registrar saidas.
    </div>
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="RegistrarSaida" method="post">
    <input asp-for="MedicamentoId" type="hidden">
    <input asp-for="MedicamentoNome" type="hidden">
    <input asp-for="MedicamentoDescricao" type="hidden">
    <input asp-for="FornecedorNome" type="hidden">
    <input asp-for="QuantidadeEmEstoque" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        <div class="fw-semibold">@Model.MedicamentoNome</div>
        <div>@Model.MedicamentoDescricao</div>
        <div class="small">Fornecedor: @Model.FornecedorNome | Estoque atual: @Model.QuantidadeEmEstoque</div>
    </div>

    <div class="mb-3">
        <label asp-for="PacienteId" class="form-label fw-semibold text-primary text-uppercase small">Paciente</label>
        <select asp-for="PacienteId" class="form-select">
            <option value="">Selecione um paciente</option>
            @foreach (OpcaoPacienteViewModel paciente in Model.Pacientes)
            {
                <option value="@paciente.Id">@paciente.Nome</option>
            }
        </select>
        <span asp-validation-for="PacienteId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantidade" class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>
        <input asp-for="Quantidade" type="number" min="1" max="@Model.QuantidadeEmEstoque" step="1" class="form-control">
        <span asp-validation-for="Quantidade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Medicamento" asp-action="Listar">Voltar</a>
        @if (Model.Pacientes.Count == 0 || Model.QuantidadeEmEstoque == 0)
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
        }
        else
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        }
    </div>
</form>
